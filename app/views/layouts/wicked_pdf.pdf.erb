<!DOCTYPE html>
<html lang="<%= current_language %>">

<head>
  <meta charset="utf-8" />
  <title>
    <%=h html_title %>
  </title>
  <meta name="description" content="<%= Redmine::Info.app_name %>" />
  <meta name="keywords" content="issue,bug,tracker" />
  <%= wicked_pdf_stylesheet_link_tag 'jquery/jquery-ui-1.9.2', 'application' %>
  <%= wicked_pdf_stylesheet_link_tag 'rtl' if l(:direction) == 'rtl' %>
  <style type="text/css">
    .red {
      color:red;
    }
  </style>
  <%= yield :header_tags -%>
</head>

<body class="<%=h body_css_classes %>">
  <div id="wrapper">
    <div id="wrapper2">
      <div id="wrapper3">

        <div id="main" class="<%= sidebar_content? ? '' : 'nosidebar' %>">
          <div id="content">
            <%= yield %>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>