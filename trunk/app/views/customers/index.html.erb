<div class="contextual">
	<% if User.current.allowed_to?(:add_customers, @project, :global => true) && (@project.nil? || Issue.allowed_target_trackers(@project).any?) %>
			<%= link_to l(:label_customer_new), new_customer_path(@project), :class => 'icon icon-add new-customer' %>
	<% end %>
	<%= link_to l(:mns_import_label), { controller: 'customers', action: 'import' }, :class => 'icon icon-multiple' %>

</div>

<h2><%= @query.new_record? ? l(:label_customer_plural) : @query.name %></h2>
<% html_title(@query.new_record? ? l(:label_customer_plural) : @query.name) %>

<%= form_tag(customers_path, :method => :get, :id => 'query_form') do %>
		<%= render :partial => 'queries/query_form' %>
<% end %>

<% if @query.valid? %>
		<% if @customers.empty? %>
				<p class="nodata"><%= l(:label_no_data) %></p>
		<% else %>
				<%= render_query_totals(@query) %>
				<%= render :partial => 'customers/list', :locals => {:customers => @customers, :query => @query} %>
				<span class="pagination"><%= pagination_links_full @customer_pages, @customer_count %></span>
		<% end %>

		<% other_formats_links do |f| %>
				<%= f.link_to_with_query_parameters 'Atom', :key => User.current.rss_key %>
				<%= f.link_to_with_query_parameters 'CSV', {}, :onclick => "showModal('csv-export-options', '350px'); return false;" %>
				<%= f.link_to_with_query_parameters 'PDF' %>
		<% end %>

		<div id="csv-export-options" style="display:none;">
			<h3 class="title"><%= l(:label_export_options, :export_format => 'CSV') %></h3>
			<%= form_tag(customers_path( :format => 'csv'), :method => :get, :id => 'csv-export-form') do %>
					<%= query_as_hidden_field_tags(@query) %>
					<p>
						<label><%= radio_button_tag 'c[]', '', true %> <%= l(:description_selected_columns) %></label><br />
						<label><%= radio_button_tag 'c[]', 'all_inline' %> <%= l(:description_all_columns) %></label>
					</p>
					<p>
						<label><%= check_box_tag 'c[]', 'description', @query.has_column?(:description) %> <%= l(:field_description) %></label>
						<label><%= check_box_tag 'c[]', 'last_notes', @query.has_column?(:last_notes) %> <%= l(:label_last_notes) %></label>
					</p>
					<% if @customer_count > Setting.issues_export_limit.to_i %>
							<p class="icon icon-warning">
								<%= l(:setting_issues_export_limit) %>: <%= Setting.issues_export_limit.to_i %>
							</p>
					<% end %>
					<p class="buttons">
						<%= submit_tag l(:button_export), :name => nil, :onclick => "hideModal(this);" %>
						<%= submit_tag l(:button_cancel), :name => nil, :onclick => "hideModal(this);", :type => 'button' %>
					</p>
			<% end %>
		</div>

<% end %>
<%= call_hook(:view_customers_index_bottom, { :customers => @customers, :project => @project, :query => @query }) %>

<% content_for :sidebar do %>
		<%= render :partial => 'customers/sidebar' %>
<% end %>

<% content_for :header_tags do %>
		<%= auto_discovery_link_tag(:atom,
																{:query_id => @query, :format => 'atom',
																 :page => nil, :key => User.current.rss_key},
																:title => l(:label_customer_plural)) %>
		<%= auto_discovery_link_tag(:atom,
																{:controller => 'journals', :action => 'index',
																 :query_id => @query, :format => 'atom',
																 :page => nil, :key => User.current.rss_key},
																:title => l(:label_changes_details)) %>
<% end %>

<%= context_menu %>
